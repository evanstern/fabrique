{
  "include": [
    "**/*",
    "**/.server/**/*",
    "**/.client/**/*",
    ".react-router/types/**/*"
  ],
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node", "vite/client"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "~/*": ["./app/*"],
      "@auth": ["./app/lib/auth/index.ts"],
      "@auth/*": ["./app/lib/auth/*"],
      "@db": ["./app/lib/db/mongo.ts"],
      "@db/*": ["./app/lib/db/*"],
      "@sessions": ["./app/lib/sessions/index.ts"],
      "@sessions/*": ["./app/lib/sessions/*"],
      "@records": ["./app/lib/records/index.ts"],
      "@records/*": ["./app/lib/records/*"],
      "@schemas": ["./app/lib/schemas/index.ts"],
      "@schemas/*": ["./app/lib/schemas/*"],
      "@graph": ["./app/lib/graph/index.ts"],
      "@graph/*": ["./app/lib/graph/*"],
      "@stream": ["./app/lib/stream/index.ts"],
      "@stream/*": ["./app/lib/stream/*"]
    },
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true
  }
}
