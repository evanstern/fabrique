#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/lib/preview-common.sh"

usage() {
  printf 'usage: %s <slug> <worktree>\n' "$(basename "$0")" >&2
}

if [[ $# -ne 2 ]]; then
  usage
  exit 2
fi

slug="$1"
worktree="$2"
preview_validate_slug "${slug}"
preview_require_jq

if [[ ! -d "${worktree}" ]]; then
  printf 'error: worktree does not exist: %s\n' "${worktree}" >&2
  exit 1
fi
worktree="$(cd "${worktree}" && pwd -P)"
preview_validate_systemd_path "${worktree}"
if [[ ! -f "${worktree}/package.json" ]]; then
  printf 'error: worktree is not a Fabrique repo root: %s\n' "${worktree}" >&2
  exit 1
fi

pnpm_path="$(command -v pnpm || true)"
if [[ -z "${pnpm_path}" ]]; then
  printf 'error: pnpm is required to start branch previews but was not found in PATH\n' >&2
  exit 1
fi
preview_validate_systemd_path "${pnpm_path}"

registry="$(preview_registry_path)"
preview_ensure_registry "${registry}"

port="$(preview_pick_port "${registry}" "${slug}")"
hostname="$(preview_hostname "${slug}")"
service_name="$(preview_service_name "${slug}")"
unit_path="$(preview_unit_path "${slug}")"
branch="$(preview_branch_for_worktree "${worktree}")"
now="$(preview_now)"

mkdir -p "$(dirname "${unit_path}")"
cat >"${unit_path}" <<EOF
[Unit]
Description=Fabrique branch preview ${slug}
After=network.target

[Service]
Type=simple
WorkingDirectory=${worktree}
EnvironmentFile=-${worktree}/.env
Environment=NODE_ENV=development
Environment=PUBLIC_URL=https://${hostname}
Environment=ARTIFACTS_DIR=${worktree}/artifacts
Environment=FABRIQUE_ALLOWED_HOSTS=${hostname},dev-fabrique.infinitynode.ai,localhost
ExecStart=${pnpm_path} exec react-router dev --host 0.0.0.0 --port ${port}
Restart=on-failure
RestartSec=2

[Install]
WantedBy=default.target
EOF

if preview_have_systemd_user; then
  preview_systemctl daemon-reload
  preview_systemctl enable "${service_name}.service"
  preview_systemctl restart "${service_name}.service"
  if preview_systemctl is-active --quiet "${service_name}.service"; then
    printf 'started %s on http://127.0.0.1:%s\n' "${service_name}" "${port}"
  else
    printf 'error: %s did not become active; inspect with: journalctl --user -u %s.service -n 100\n' "${service_name}" "${service_name}" >&2
    exit 1
  fi
else
  printf 'wrote systemd user unit but could not contact systemd --user in this shell\n' >&2
  printf 'manual start: systemctl --user daemon-reload && systemctl --user enable --now %s.service\n' "${service_name}" >&2
fi

tmp="$(mktemp "${registry}.tmp.XXXXXX")"
preview_read_registry "${registry}" | jq \
  --arg slug "${slug}" \
  --arg branch "${branch}" \
  --arg worktree "${worktree}" \
  --arg hostname "${hostname}" \
  --arg service_name "${service_name}" \
  --arg created_at "${now}" \
  --arg updated_at "${now}" \
  --argjson port "${port}" \
  '.[$slug] = {
    slug: $slug,
    branch: $branch,
    worktree: $worktree,
    port: $port,
    hostname: $hostname,
    service_name: $service_name,
    created_at: (.[$slug].created_at // $created_at),
    updated_at: $updated_at
  }' >"${tmp}"
mv "${tmp}" "${registry}"

printf 'registered preview: https://%s\n' "${hostname}"
printf 'registry: %s\n' "${registry}"
preview_print_route_snippets "${slug}" "${port}"
