# Copy to .env and fill in MONGO_URL and ANTHROPIC_API_KEY.
# .env is gitignored; never commit it.

# Required: Anthropic API key for LLM-powered workflow nodes
# (ingest_brief, clarify_or_confirm_brief). Format: sk-ant-...
ANTHROPIC_API_KEY=

# Required: Mongo connection string.
# Fabrique uses MongoDB Atlas (free tier is fine for dev).
# Format:
#   mongodb+srv://<user>:<password>@<cluster-host>/<db>?retryWrites=true&w=majority
# Example:
#   MONGO_URL=mongodb+srv://fabrique-app:somepassword@cluster0.abcde.mongodb.net/fabrique?retryWrites=true&w=majority
MONGO_URL=

# Required: shared password gating all routes. Anyone with this password
# sees the entire site.
FABRIQUE_PASSWORD=

# Required: HMAC secret used to sign auth cookies. Rotating this value
# invalidates all existing cookies (= "log everyone out").
# Generate with: openssl rand -hex 32
FABRIQUE_AUTH_SECRET=

# Optional: host port the app is exposed on (container always serves on 3000).
APP_HOST_PORT=8422

# Optional: base URL the app uses to generate artifact links.
# In dev this is the host port; in production this is the public URL
# (e.g. https://fabrique.infinitynode.ai).
PUBLIC_URL=http://localhost:8422
